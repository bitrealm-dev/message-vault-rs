# Copy to config.toml and edit for your machine:
#   cp config/config.toml.example config/config.toml
#   cp config/contacts.csv.example config/contacts.csv
#   cp config/exclude.csv.example config/exclude.csv
#
# Real config/contacts/exclude files are gitignored.
#
# Instance config: paths and import sources only. Vault owner profile and web login
# accounts live in SQLite (`vault_owners`, `accounts`). CLI commands require `--account <uuid>`.
#
# Optional legacy sections (used by `reset-demo` seeding when present):
# [owner] — message / vault owner for demo seeding
# [account] — web login account stub
#
# Staging (`export_dir`) is filled outside this repo (e.g. message-exporters).
# Then run: cargo run --release -- ingest <source> --account <uuid>
#
# contacts.csv: phone numbers only (semicolon-separated). Set exclude=true to hide from
# Contacts/groups (All still lists them). iMessage emails attach in the UI into
# contact_handles (DB only) — never written to this CSV.
# Older contact_phones / preferred_phone DBs are not upgraded — wipe vault.db and re-ingest.
# exclude.csv: handles skipped entirely on import (short codes, banks, etc.).

# [owner]
# display_name = "Your Name"
# phones = ["+15555550100"]
# emails = ["you@backup.example.com"]
#
# [account]
# username = "yourname"
# login_email = "you@example.com"
# read_only = false

[paths]
db = "data/vault.db"
data_dir = "data"
assets_dir = "assets"
assets_converted_dir = "assets_converted"
contacts_csv = "config/contacts.csv"
exclude_csv = "config/exclude.csv"

[[sources]]
id = "imessage"
export_dir = "staging/imessage"

[[sources]]
id = "sms-backup-plus"
export_dir = "staging/sms-backup-plus-eml"

[[sources]]
id = "go-sms-pro"
export_dir = "staging/go-sms-pro"

[[sources]]
id = "sms-backup-restore"
export_dir = "staging/sms-backup-restore"
